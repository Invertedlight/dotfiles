#!/bin/bash

# Description: Link dotfiles to home directory

[ -f ~/.config ] || mkdir -p ~/.config
[ -f ~/.vim/templates ] || mkdir -p ~/.vim/templates

ln -sf ~/dotfiles/bashrc ~/.bashrc
ln -sf ~/dotfiles/vimrc ~/.vimrc
ln -sf ~/dotfiles/starship.toml ~/.config/starshp.toml
ln -sf ~/dotfiles/vim/templates ~/.vim/templates

echo "Dotfiles linked!"

